{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "${JWT_SECRET}",
    "Issuer": "SpokenEnglishAPI",
    "Audience": "SpokenEnglishClient",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "SE_DB": "${DATABASE_URL}"
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "${ALLOWED_ORIGIN}",
    "https://localhost:5173"
  ]
}
